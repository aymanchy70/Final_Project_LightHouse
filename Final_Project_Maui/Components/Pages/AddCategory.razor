@page "/categories/add"
@using Final_Project_Maui.Models
@using Final_Project_Maui.Services
@inject ItemCategoryService CategoryService
@inject NavigationManager Navigation

<h3>Add New Category</h3>

<EditForm Model="@newCategory" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" />

    <div class="mb-3">
        <label for="categoryName" class="form-label">Category Name</label>
        <InputText id="categoryName" class="form-control" @bind-Value="newCategory.CategoryName" />
        <ValidationMessage For="@(() => newCategory.CategoryName)" />
    </div>

    <div class="mb-3">
        <label for="categoryDesc" class="form-label">Description (optional)</label>
        <InputText id="categoryDesc" class="form-control" @bind-Value="newCategory.CategoryDescription" />
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
</EditForm>

@code {
    private ItemCategoryDto newCategory = new ItemCategoryDto();

    private async Task HandleValidSubmit()
    {
        await CategoryService.CreateCategoryAsync(newCategory);
        Navigation.NavigateTo("/categories");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/categories");
    }
}